class Solution {

    int maxValue(int arr[]) {
        long sum = 0;
        int mod = 1000000007;
        
        Arrays.sort(arr);
        
        for(int i = 0; i < arr.length; i++){
            sum = (sum + ((long)arr[i] * i) % mod) % mod;
        }
        
        return (int) sum;
    }
}
