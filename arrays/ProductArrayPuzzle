class Solution {
    public static int[] productExceptSelf(int arr[]) {
        int n = arr.length;
        int[] res = new int[n];

        res[0] = 1;

        // Prefix
        for(int i = 1; i < n; i++){
            res[i] = res[i-1] * arr[i-1];
        }

        // Suffix
        int right = 1;
        for(int i = n-1; i >= 0; i--){
            res[i] = res[i] * right;
            right = right * arr[i];
        }

        return res;
    }
}
